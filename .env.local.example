# ============================================================
# Environment Variables — Futuro Me
# ============================================================
# NEXT_PUBLIC_ prefix = exposed to the browser (safe if RLS is on)
# No prefix = server-only (API routes, cron jobs, server actions)
# ============================================================

# --- Supabase ---
# Browser client (safe: restricted by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only client with elevated privileges (bypasses RLS)
# Used in API routes and cron jobs. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Authentication ---
# Vercel cron job secret (validated in /api/cron/* routes)
CRON_SECRET=your-cron-secret

# Admin API secret (validated in /api/admin/* routes, falls back to CRON_SECRET)
ADMIN_SECRET=your-admin-secret

# --- External APIs ---
# NewsAPI key for fetching news articles (optional, server-only)
NEWS_API_KEY=your-newsapi-key

# --- Site Configuration ---
# Public base URL (used for sitemap, canonical URLs, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://ilfuturome.it
